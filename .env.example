LITTLE_HELPER_ENV=development
LITTLE_HELPER_LOG_LEVEL=info
LITTLE_HELPER_ARTIFACT_DIR=.little-helper/runs
LITTLE_HELPER_LLM_PROVIDER=openai
LITTLE_HELPER_LLM_MODEL=gpt-5.4
# LITTLE_HELPER_LLM_BASE_URL=https://api.openai.com/v1
# LITTLE_HELPER_LLM_ORGANIZATION=org_123
# LITTLE_HELPER_LLM_PROJECT=proj_123
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
# Role-specific routing can be configured in .little-helper.config.json via llmRouting.
LITTLE_HELPER_MAX_ITERATIONS=3
LITTLE_HELPER_APPROVAL_MODE=on-risk
